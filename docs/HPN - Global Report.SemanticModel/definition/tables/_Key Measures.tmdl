	measure 'Gross Sales Last Year' = CALCULATE([Gross Sales], SAMEPERIODLASTYEAR(dCalendar[DateId]))
		lineageTag: 5f2db99b-af9c-4593-82c0-36b128a0a97b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MoM % Gross Sales' =
			
			VAR vGrossSalesPM= CALCULATE([Gross Sales],DATEADD(dCalendar[DateId],-1,MONTH))
			RETURN
			DIVIDE([Gross Sales]-vGrossSalesPM,[Gross Sales])
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e1a133a6-f78b-4c24-83e1-d4265acb1259

	measure 'YoY% Gross Sales' =
			
			VAR vGrossSalesLY = CALCULATE([Gross Sales],SAMEPERIODLASTYEAR(dCalendar[DateId]))
			RETURN
			DIVIDE([Gross Sales]-vGrossSalesLY,[Gross Sales])
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 3dc02118-6aff-4269-954c-7e395b2b5c0a

	measure 'Gross Sales 2014' = ```
			
			VAR vGrossSales2013 = CALCULATE([Gross Sales],dCalendar[Year] = 2013)
			VAR vGrossSales2012 = CALCULATE([Gross Sales],dCalendar[Year] = 2012)
			Return
			   IF(
			    MAX(dCalendar[MonthName]) = "May",vGrossSales2013*2,
			    IF(
			    MAX(dCalendar[MonthName]) = "December",(vGrossSales2012*1.1)*1.1,
			    vGrossSales2013*1.1))
			 
			```
		isHidden
		lineageTag: 87a5ac28-8415-4bf8-86a2-0b1d31c5c0ce

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gross Sales 2014 v2' = ```
			
			VAR vGrossSales2013 = CALCULATE([Gross Sales],dCalendar[Year] = 2013)
			VAR vGrossSales2012 = CALCULATE([Gross Sales],dCalendar[Year] = 2012)
			Return
			    SUMX(
			        CALCULATETABLE(VALUES(dCalendar[YearMonthNumber]), dCalendar[Year] = 2013),
			        [Gross Sales] * IF(dCalendar[YearMonthNumber] == 201305, 2, 1.1)
			    )
			 
			```
		isHidden
		lineageTag: c666e7be-ef39-4c53-b0d5-fcbcd1861105

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gross Sales 2014 v3' =
			
			VAR vGrossSales2013 = CALCULATE([Gross Sales],dCalendar[Year] = 2013)
			VAR vGrossSales2012 = CALCULATE([Gross Sales],dCalendar[Year] = 2012)
			Return
			    SUMX(
			        CALCULATETABLE(VALUES(dCalendar[YearMonthNumber]), dCalendar[Year] = 2013),
			        IF(dCalendar[YearMonthNumber] == 201312,CALCULATE([Gross Sales],dCalendar[YearMonthNumber] == 201212) *1.21,[Gross Sales] * IF(dCalendar[YearMonthNumber] == 201305, 2, 1.1))
			    )
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 70b86d87-3b51-40aa-bb51-575039b2ecda

