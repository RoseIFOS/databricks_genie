	measure 'Average Margin Last 3 Months' =
			
			VAR vDatamaxlastmonth = CALCULATE(MAX(dCalendar[DateId]),DATEADD(dCalendar[DateId],-1,MONTH))
			VAR vDataminprevios3months = CALCULATE(MIN(dCalendar[DateId]),DATEADD(dCalendar[DateId],-3,MONTH))
			RETURN
			CALCULATE(
			    DIVIDE([Gross Margin],[Net Sales]),
			    DATESBETWEEN(dCalendar[DateId],vDataminprevios3months,vDatamaxlastmonth)
			)
