	measure 'DT Text Subcategory' =
			
			"Filtered by " & SELECTEDVALUE(dProduct[SubcategoryName])
		displayFolder: _Customer Classification Matrix
		lineageTag: 8dd51d44-dc63-4c1e-9c29-141093d65d27

		annotation PBI_FormatHint = {"isText":true}

	measure 'Frequency & Monetary Value' = ```
			
			VAR vRmin = MIN(auxClassRFM[RMin])
			VAR vRmax = MAX(auxClassRFM[RMax])
			VAR vFMmin = MIN(auxClassRFM[FMMin])
			VAR vFMmax = MAX(auxClassRFM[FMMax])
			VAR vfm = 
			CALCULATE(
			    [RFM - FM],
			    FILTER(
			        VALUES(dCustomer[Customer]),
			        [RFM - R] > vRmin && [RFM - R] <= vRmax
			        &&
			        [RFM - FM] > vFMmin && [RFM - FM] <= vFMmax
			    )
			)
			RETURN
			vfm
			```
		formatString: 0.0
		displayFolder: _Customer Classification Matrix
		lineageTag: 46caa419-531d-40d4-b39a-ed322d18fc95

	measure Recency = ```
			
			VAR vRmin = MIN(auxClassRFM[RMin])
			VAR vRmax = MAX(auxClassRFM[RMax])
			VAR vFMmin = MIN(auxClassRFM[FMMin])
			VAR vFMmax = MAX(auxClassRFM[FMMax])
			VAR vr = 
			CALCULATE(
			    [RFM - R],
			    FILTER(
			        VALUES(dCustomer[Customer]),
			        [RFM - R] > vRmin && [RFM - R] <= vRmax
			        &&
			        [RFM - FM] > vFMmin && [RFM - FM] <= vFMmax
			    )
			)
			RETURN
			vr
			```
		formatString: 0.0
		displayFolder: _Customer Classification Matrix
		lineageTag: d4c969e2-ba56-429a-98bc-0db2848bb798

	measure 'RFM - F' = ```
			
			VAR vSalesOrders =  DISTINCTCOUNT(fSalesDetails[SalesOrderNumber])
			VAR vSOLast12M =
			CALCULATE(
			    vSalesOrders,
			    DATESINPERIOD(
			        fSalesDetails[OrderDate],
			        MAX(fSalesDetails[OrderDate]),
			        -12,
			        MONTH
			    )
			)
			VAR vResult = 
			    SWITCH(
			        TRUE(),
			        vSalesOrders >= 5, 5,
			        vSalesOrders >= 4, 4,
			        vSalesOrders >= 3, 3,
			        vSalesOrders >= 2, 2,
			        vSalesOrders >= 1, 1
			    )
			
			RETURN vResult
			```
		formatString: 0
		displayFolder: _Customer Classification Matrix
		lineageTag: 52307108-f6e7-4bbf-9b17-ebd81eac9f70

	measure 'RFM - FM' = DIVIDE(([RFM - F]+[RFM - M]),2)
		displayFolder: _Customer Classification Matrix
		lineageTag: f93fb315-af29-40a5-8c5b-ff69e91ce6cc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'RFM - M' = ```
			
			VAR vGrossSales = SUMX(fSalesDetails, fSalesDetails[OrderQuantity] * fSalesDetails[UnitPrice])
			VAR vQty = 
			CALCULATE(
			    vGrossSales,
			    DATESINPERIOD(
			        fSalesDetails[OrderDate],
			        MAX(fSalesDetails[OrderDate]),
			        -12,
			        MONTH
			    )
			)
			VAR vResult = 
			    SWITCH(
			        TRUE(),
			        vQty >= 300000, 5,
			        vQty >= 200000, 4,
			        vQty >= 100000, 3,
			        vQty >= 10000, 2,
			        vQty > 0, 1
			    )
			
			RETURN vResult
			```
		formatString: 0
		displayFolder: _Customer Classification Matrix
		lineageTag: 156b40f1-2667-4353-84e5-f0e840e009a0

	measure 'RFM - R' = ```
			
			VAR vLastPurchase = MAX(fSalesDetails[OrderDate])
			VAR vMaxDate = MAX(dCalendar[DateId])
			VAR vDifDate = DATEDIFF(vLastPurchase, vMaxDate, DAY)
			VAR vResult = 
			    SWITCH(
			        TRUE(),
			        vDifDate >  360, 1,
			        vDifDate > 270 && vDifDate <= 360, 2,
			        vDifDate > 180 && vDifDate <= 270, 3,
			        vDifDate > 90 && vDifDate <= 180, 4,
			        vDifDate > 0 && vDifDate <= 90, 5,
			        BLANK()
			    )
			
			RETURN vResult
			```
		formatString: 0
		displayFolder: _Customer Classification Matrix
		lineageTag: ea0858c4-aee6-46fc-9112-474a9a55dac4

	measure 'About to Sleep' = ```
			
			VAR vResult = 
			CALCULATE(
			    [Customers - Current],
			    FILTER(
			        VALUES(fSalesDetails[CustomerKey]),
			        [RFM - R]>2&&[RFM - R]<=3&&[RFM - FM]>0&&[RFM - FM]<=2
			    )
			)
			RETURN
			vResult+0
			```
		displayFolder: _Customer Classes
		lineageTag: 84ea2f97-edf0-4bfd-86eb-80b19dd1c8d8

