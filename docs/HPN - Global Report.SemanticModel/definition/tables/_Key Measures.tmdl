	measure 'Gross Sales by RFM' = ```
			
			VAR vRmin = MIN(auxClassRFM[RMin])
			VAR vRmax = MAX(auxClassRFM[RMax])
			VAR vFMmin = MIN(auxClassRFM[FMMin])
			VAR vFMmax = MAX(auxClassRFM[FMMax])
			VAR vgross = 
			CALCULATE(
			    [Gross Sales Last 12M],
			    FILTER(
			        VALUES(dCustomer[Customer]),
			        [RFM - R] > vRmin && [RFM - R] <= vRmax
			        &&
			        [RFM - FM] > vFMmin && [RFM - FM] <= vFMmax
			    )
			)
			RETURN
			vgross
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: bc553dfe-422c-4883-9251-a981f76fa86d

	measure 'Last Puchase by RFM' = ```
			
			VAR vRmin = MIN(auxClassRFM[RMin])
			VAR vRmax = MAX(auxClassRFM[RMax])
			VAR vFMmin = MIN(auxClassRFM[FMMin])
			VAR vFMmax = MAX(auxClassRFM[FMMax])
			VAR vlast = 
			CALCULATE(
			    [Last Purchase],
			    FILTER(
			        VALUES(dCustomer[Customer]),
			        [RFM - R] > vRmin && [RFM - R] <= vRmax
			        &&
			        [RFM - FM] > vFMmin && [RFM - FM] <= vFMmax
			    )
			)
			RETURN
			vlast
			```
