	measure 'Customers Class' =
			
			VAR vClassrvm= SELECTEDVALUE(auxClassRFM[Class])
			RETURN
			SWITCH(
			    TRUE(),
			    vClassrvm = "Champions", [Champions],
			    vClassrvm = "Loyal Customers", [Loyal Customers],
			    vClassrvm = "Potential Loyalist", [Potential Loyalist],
			    vClassrvm = "New Customers", [New Customers],
			    vClassrvm = "Hibernating", [Hibernating],
			    vClassrvm = "Promising", [Promising],
			    vClassrvm = "Needing Attention", [Needing Attention],
			    vClassrvm = "About to Sleep", [About to Sleep],
			    vClassrvm = "Can't Lose Then", [Can't Lose Them],
			    vClassrvm = "At Risk", [At Risk],
			    vClassrvm = "Lost", [Lost],
			    BLANK()
			)
		formatString: 0
		displayFolder: _Customer Classification Matrix
		lineageTag: 3224e641-4204-4f9a-ac2e-0703b51ef329

	measure 'Customers RFM' = ```
			
			VAR vToday = MAX(dCalendar[DateId])
			VAR vResult = 
			CALCULATE(
			    [Customers - Current],
			    FILTER(
			        VALUES(fSalesDetails[CustomerKey]),
			        VAR vLast = 
			        CALCULATE(
			            MAX(fSalesDetails[OrderDate]),
			            FILTER(
			                ALL(dCalendar),
			                dCalendar[DateId] <= MAX(fSalesDetails[OrderDate])
			            )
			        )
			        RETURN
			        [Sales Orders Last 12M] >= MIN(auxFrequency[LowerT]) &&
			        [Sales Orders Last 12M] < MAX(auxFrequency[UpperT]) &&
			        DATEDIFF(vLast, vToday, DAY) >= MIN(auxRecency[LowerT]) &&
			        DATEDIFF(vLast, vToday, DAY) < MAX(auxRecency[UpperT])&&
			        [Gross Sales Last 12M] >=MIN(auxMonetary[LowerT])&&
			        [Gross Sales Last 12M] <MAX(auxMonetary[UpperT])
			    )
			)
			RETURN
			vResult
			```
		formatString: 0
		displayFolder: _Customer Classification Matrix
		lineageTag: d64bf710-91f1-4bac-a8c9-5d9de7a2944d

	measure 'DT Text Class' =
			
			"Filtered by " & SELECTEDVALUE(auxClassRFM[Class])
		displayFolder: _Customer Classification Matrix
		lineageTag: 55efc6f3-0c00-4e49-b58a-e9f16548986c

