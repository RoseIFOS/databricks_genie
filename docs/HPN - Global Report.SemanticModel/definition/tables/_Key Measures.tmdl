	measure 'Gross Sales 2013' =
			
			VAR vbudgetdec2013 =CALCULATE([Gross Sales],dCalendar[YearMonthNumber]=201212)*1.1
			Return
			 SUMX(
			        CALCULATETABLE(VALUES(dCalendar[YearMonthNumber]), dCalendar[Year] = 2013),
			        IF(dCalendar[YearMonthNumber] == 201312,vbudgetdec2013,
			        CALCULATE([Gross Sales],dCalendar[Year]=2013
			
			)))
