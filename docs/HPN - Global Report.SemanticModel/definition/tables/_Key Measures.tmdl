	measure 'Customers Average Sales on Country' =
			
			VAR contaclientespais = CALCULATE(
			    DISTINCTCOUNT(dCustomer[CustomerKey]),
			    FILTER(ALL(dCustomer[CustomerKey],dCustomer[Customer],dCustomer[CityName],dCustomer[Region.1]), [Gross Sales] > 0),
			    VALUES(dCustomer[CountryName]))
			VAR vCalc = CALCULATE(
			    [Gross Sales],
			    FILTER(ALL(dCustomer[CustomerKey],dCustomer[Customer], dCustomer[Region.1],dCustomer[CityName]), [Gross Sales]>0),
			    VALUES(dCustomer[CountryName])
			)
			VAR DIVID = DIVIDE(vCalc,contaclientespais)
			RETURN
			IF([Gross Sales]>0,DIVID,BLANK())
		formatString: \$#,0;(\$#,0);\$#,0
