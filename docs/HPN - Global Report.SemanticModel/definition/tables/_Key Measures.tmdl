	measure 'Total Amount' = ```
			CALCULATE(
			    SUMX(fFinance, fFinance[Amount]*RELATED(dAccount[Sign])),
			    fFinance[Scenario]="actual"
			)
			
			```
		displayFolder: _Income Statement
		lineageTag: 8bd12cfc-6a79-4dde-8ded-371a40014d32

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Amount Actual' =
			
			VAR ESCOPOCONTA = ISINSCOPE(dAccount[Account])
			VAR ESCOPOSUBCONTA = ISINSCOPE(dAccount[AccountSubheader])
			VAR MAXDETAIL = SELECTEDVALUE(dAccountHeader[Detail])
			VAR MAXDETAILSUB = SELECTEDVALUE(dAccount[SubheaderDetail])
			RETURN
			SWITCH(
			    TRUE(),
			    MAXDETAIL = FALSE && ESCOPOSUBCONTA = FALSE(), [Subtotal Amount],
			    MAXDETAIL = TRUE && MAXDETAILSUB = FALSE && ESCOPOCONTA = TRUE(), BLANK(),
			   [Total Amount]
			)
		displayFolder: _Income Statement
		lineageTag: 4fa7cfe5-d428-4708-8dbe-e6a113d3b216

	measure 'Total Amount Budget' = ```
			
			VAR CALCVALOR = CALCULATE(
			    SUMX(fFinance, fFinance[Amount]*RELATED(dAccount[Sign])),
			    fFinance[Scenario]="budget"
			)
			VAR SEQMAX = MAX(dAccountHeader[AccountHeaderKey])
			VAR CALCVALORSUB =  
			    CALCULATE(CALCULATE(
			    SUMX(fFinance, fFinance[Amount]*RELATED(dAccount[Sign])),
			    fFinance[Scenario]="budget"),
			    FILTER(ALL(dAccountHeader), dAccountHeader[AccountHeaderKey] <= SEQMAX)
			    )
			VAR ESCOPOCONTA = ISINSCOPE(dAccount[Account])
			VAR ESCOPOSUBCONTA = ISINSCOPE(dAccount[AccountSubheader])
			VAR MAXDETAIL = SELECTEDVALUE(dAccountHeader[Detail])
			VAR MAXDETAILSUB = SELECTEDVALUE(dAccount[SubheaderDetail])
			RETURN
			SWITCH(
			    TRUE(),
			    MAXDETAIL = FALSE && ESCOPOSUBCONTA = FALSE(), CALCVALORSUB,
			    MAXDETAIL = TRUE && MAXDETAILSUB = FALSE && ESCOPOCONTA = TRUE(), BLANK(),
			   CALCVALOR
			)
			```
		displayFolder: _Income Statement
		lineageTag: 8780e814-dc1c-4f55-8313-393c6e5772ec

		annotation PBI_FormatHint = {"isGeneralNumber":true}

