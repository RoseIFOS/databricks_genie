	measure 'Gross Sales' = SUMX(fSalesDetails, fSalesDetails[OrderQuantity] * fSalesDetails[UnitPrice])
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: be8ef380-b6f8-43d9-8ccd-cec2d2073230

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Gross Sales Last 12M' =
			
			CALCULATE(
			    [Gross Sales],
			    DATESINPERIOD(
			        fSalesDetails[OrderDate],
			        MAX(fSalesDetails[OrderDate]),
			        -12,
			        MONTH
			    )
			)
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 046ced6a-f37d-426f-ac81-01b5b31d77ac

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Last Purchase' = MAX(fSalesDetails[OrderDate])
		formatString: d/m/yyyy
		lineageTag: f1afcfe6-4d0e-4754-a63b-4aa575abd4ae

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	measure 'Sales Orders Last 12M' =
			
			VAR vSalesOrders =  DISTINCTCOUNT(fSalesDetails[SalesOrderNumber])
			RETURN
			CALCULATE(
			    vSalesOrders,
			    DATESINPERIOD(
			        fSalesDetails[OrderDate],
			        MAX(fSalesDetails[OrderDate]),
			        -12,
			        MONTH
			    )
			)
		formatString: 0
		lineageTag: 82f9d227-4827-475b-8959-2fb1beb456e1

	measure 'Customers - Recurrent (PY)' = ```
			
			VAR vPreviousY = 
			CALCULATETABLE(
			    VALUES(fSalesDetails[CustomerKey]),
			    PREVIOUSYEAR(dCalendar[DateId])
			)
			VAR vThisY = VALUES(fSalesDetails[CustomerKey])
			
			VAR vBothY = INTERSECT(vPreviousY,vThisY)
			
			RETURN
			COUNTROWS(vBothY)
			```
		formatString: 0
		displayFolder: _Customers
		lineageTag: 43539841-e991-438b-a881-4b4f1367c744

	measure 'Customers - Recurrent%' =
			
			divide([Customers - Recurrent (PY)],[Customers - All])
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: _Customers
		lineageTag: 093411f7-710b-4874-b010-c107d632001c

	measure 'Customers - Without Sales' =
			
			VAR vAll  = VALUES(dCustomer[CustomerKey])
			VAR vCurrent = VALUES(fSalesDetails[CustomerKey])
			
			VAR vExcept = EXCEPT(vAll,vCurrent)
			RETURN
			COUNTROWS(vExcept)
		formatString: 0
		displayFolder: _Customers
		lineageTag: 8bfdf691-d473-4e8a-a324-7d6932250e10

	measure 'Customers - Without Sales%' = DIVIDE([Customers - Without Sales],[Customers - All])
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: _Customers
		lineageTag: 2e4b0424-cafd-4d39-bb1b-c27e48f27be8

	measure 'Customers - New' =
			
			VAR vCurrent = VALUES(fSalesDetails[CustomerKey])
			VAR vOld  =
			CALCULATETABLE(
			    VALUES(fSalesDetails[CustomerKey]),
			    FILTER(
			        ALL(dCalendar),
			        dCalendar[DateId] < MIN(dCalendar[DateId])
			    )
			)
			VAR vExcept = EXCEPT(vCurrent,vOld)
			RETURN
			COUNTROWS(vExcept)
		formatString: 0
		displayFolder: _Customers
		lineageTag: 6e065398-3ff8-4cb6-a526-aa4cff22d943

	measure 'Customers - New%' = DIVIDE([Customers - New],[Customers - All])
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: _Customers
		lineageTag: 0e0ac276-44b2-4219-91a0-40d652578700

	measure 'Gross Sales CY' =
			
			VAR AnoAtual = SELECTEDVALUE(dCalendar[Year])
			RETURN
			CALCULATE([Gross Sales],dCalendar[Year] = AnoAtual)
		lineageTag: cba9380a-1087-46df-b70d-5ec98781c207

