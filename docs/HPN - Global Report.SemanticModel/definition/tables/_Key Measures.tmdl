	measure 'Product Average Sales on Subcategory' =
			
			VAR contaprodutossubcategoria = CALCULATE(
			    DISTINCTCOUNT(dProduct[ProductKey]),
			    FILTER(ALL(dProduct[ProductKey],dProduct[ProductName], dProduct[Detail]), [Gross Sales] > 0),VALUES(dProduct[SubcategoryName]))
			VAR vCalc = CALCULATE(
			    [Gross Sales],
			    FILTER(ALL(dProduct[ProductKey],dProduct[ProductName], dProduct[Detail]), [Gross Sales]>0),
			    VALUES(dProduct[SubcategoryName])
			)
			VAR DIVID = DIVIDE(vCalc,contaprodutossubcategoria)
			RETURN
			IF([Gross Sales]>0,DIVID,BLANK())
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 68b8e5fd-e221-416f-a67c-3bb5d6efea63

